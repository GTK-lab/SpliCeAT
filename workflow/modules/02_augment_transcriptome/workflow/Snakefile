rule all:
	input:
		# stringtie outputs
		expand(os.path.join(ST_DIR,"{sample}_ref_guided_assembly.gtf"),sample=SAMPLES),
		os.path.join(ST_DIR,"stringtie_assembly.gtf"),

		# augmentation final outputs
